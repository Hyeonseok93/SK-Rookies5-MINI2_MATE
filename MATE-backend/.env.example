# Runtime profile
SPRING_PROFILES_ACTIVE=dev

# MariaDB
DB_URL=jdbc:mariadb://localhost:3306/mate_db?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USER=root
DB_PASSWORD=change_me

# JWT (use a random value with at least 32 characters)
JWT_SECRET=replace_with_a_random_secret_of_at_least_32_characters

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# CORS allowed origins (comma-separated). Default in app is http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Refresh cookie (set true behind HTTPS in production)
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=Lax

# Authentication API rate limits per IP/path and window
AUTH_RATE_LIMIT_ENABLED=true
AUTH_LOGIN_RATE_LIMIT=5
AUTH_RECOVERY_RATE_LIMIT=3
AUTH_RATE_LIMIT_WINDOW_SECONDS=60